# 当前项目本地环境：Windows + PowerShell + conda
APP_NAME=CitrusAgent
APP_ENV=local
PROJECT_ROOT=G:/py_workplace/CitrusAgent
PYTHONPATH=G:/py_workplace/CitrusAgent

# API
API_V1_PREFIX=/api/v1

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=orange_knowledge
QDRANT_DISTANCE=Cosine
#广西大学服务器上面的
QDRANT_HYBRID_COLLECTION=orange_knowledge_hybrid
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
# Embedding
EMBEDDING_PROVIDER=api
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_VECTOR_SIZE=1024
#广西大学服务器上面的BGE_M3模型
BGE_M3_URL=http://172.21.72.18:8001
BGE_M3_TIMEOUT=60
BGE_M3_BATCH_SIZE=8

# Retrieval
RETRIEVAL_TOP_K=30
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=258013CH
MYSQL_DATABASE=CitrusAgent
DATABASE_URL=mysql+pymysql://root:258013CH@localhost:3306/CitrusAgent?charset=utf8mb4
