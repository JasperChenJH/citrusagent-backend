# 当前项目本地环境：Windows + PowerShell + conda
APP_NAME=CitrusAgent
APP_ENV=local
PROJECT_ROOT=G:/py_workplace/CitrusAgent
PYTHONPATH=G:/py_workplace/CitrusAgent

# API
API_V1_PREFIX=/api/v1

# DeepSeek
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=agriculture_knowledge

# Database
DATABASE_URL=sqlite:///./citrus_agent.db
