# 当前项目本地环境：Windows + PowerShell + conda
APP_NAME=CitrusAgent
APP_ENV=local
PROJECT_ROOT=G:/py_workplace/CitrusAgent
PYTHONPATH=G:/py_workplace/CitrusAgent

# API
API_V1_PREFIX=/api/v1

# DeepSeek
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Qdrant
QDRANT_URL=http://192.168.157.128:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=orange_knowledge
QDRANT_HYBRID_COLLECTION=orange_knowledge_hybrid
QDRANT_DISTANCE=Cosine
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse

# Embedding
EMBEDDING_PROVIDER=api
EMBEDDING_API_KEY=replace-me
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_VECTOR_SIZE=1024
BGE_M3_URL=http://172.21.72.18:8001
BGE_M3_TIMEOUT=60
BGE_M3_BATCH_SIZE=8
QWEN_RERANKER_URL=http://172.21.72.18:8002
QWEN_RERANKER_MODEL=qwen3-reranker-4b
QWEN_RERANKER_TIMEOUT=60
QWEN_RERANKER_BATCH_SIZE=16

# Retrieval
RETRIEVAL_TOP_K=30
HYBRID_DENSE_TOP_K=40
HYBRID_SPARSE_TOP_K=40
HYBRID_CANDIDATE_TOP_K=25
HYBRID_FINAL_TOP_K=8
HYBRID_RRF_K=60
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace-me
MYSQL_DATABASE=CitrusAgent
DATABASE_URL=mysql+pymysql://root:replace-me@localhost:3306/CitrusAgent?charset=utf8mb4
